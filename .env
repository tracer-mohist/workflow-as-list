# WorkflowAsList Environment Configuration
# Commit this file with sensible defaults
# Override with .env.local for local development (not committed)

# Application
WF_DEBUG=false

# Server
WF_HOST=127.0.0.1
WF_PORT=8080

# Security
WF_TOKEN_MIN=282
WF_TOKEN_MAX=358

# Paths
WF_CONFIG_DIR=~/.config/wf
